# SSH (bastion)
SSH_HOST=your.ssh.host
SSH_PORT=22
SSH_USER=ec2-user
SSH_PKEY_PATH=/absolute/path/to/key.pem

# Redshift
REDSHIFT_HOST=your-redshift-cluster.xxxxxx.region.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DBNAME=dev
REDSHIFT_USER=rs_user
REDSHIFT_PASSWORD=your_password

# App
LOG_LEVEL=INFO
OUTPUT_DIR=./output